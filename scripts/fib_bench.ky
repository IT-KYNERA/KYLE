## Prime counting benchmark — count primes up to 3000000 (3M)
fn is_prime(n: i32) bool:
    if n < 2:
        return false
    i: &i32 = 2
    while i * i <= n:
        if n % i == 0:
            return false
        i = i + 1
    true

fn main() i32:
    count: &i32 = 0
    n: &i32 = 2
    while n < 3000000:
        if is_prime(n):
            count = count + 1
        n = n + 1
    println(str(count))
    0
