# Kyle — Sieve of Eratosthenes (3M)
fn main() i32:
    n = 3000000
    sieve: {i32} = {0}
    i = 0
    while i < n + 1:
        sieve.push(0)
        i = i + 1
    primes: {i32} = {0}
    primes.pop()
    i2 = 2
    while i2 <= n:
        if sieve.get(i2) == 0:
            primes.push(i2)
            j = i2 + i2
            while j <= n:
                sieve.set(j, 1)
                j = j + i2
        i2 = i2 + 1
    println(primes.len().to_str())
    0
