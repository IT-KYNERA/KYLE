fn main() i32:
    n := 100000
    sieve: [i32; 100001] = []
    i: &i64 = 0
    while i <= n:
        sieve[i] = 0
        i = i + 1
    count: &i32 = 0
    i2: &i64 = 2
    while i2 <= n:
        if sieve[i2] == 0:
            count = count + 1
            j: &i64 = i2 + i2
            while j <= n:
                sieve[j] = 1
                j = j + i2
        i2 = i2 + 1
    println(str(count))
    0
