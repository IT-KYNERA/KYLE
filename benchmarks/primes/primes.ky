# Kyle — Sieve of Eratosthenes
fn main() i32:
    n := 1000000
    count: &i32 = 0
    i: &i32 = 2
    while i <= n:
        is_prime: &i32 = 1
        j: &i32 = 2
        while j * j <= i:
            if i % j == 0:
                is_prime = 0
            j = j + 1
        if is_prime == 1:
            count = count + 1
        i = i + 1
    println("Primes: {count}")
    0
