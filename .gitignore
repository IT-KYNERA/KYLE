# === Rust / Cargo ===
target/

# Cargo.lock should be committed for binaries (Kyle is a binary, not a library)
# Do NOT ignore Cargo.lock

# === KL build artifacts ===
*.o
*.ll
*.bc
*.kyc
*.klc
.kyc-build/
klc-build/
.klc-build/
build/

# === KL compiled benchmarks ===
benchmarks/target/

# === Multi-language benchmark artifacts ===
# C / C++
benchmarks/*/**_c
benchmarks/*/**_cpp

# Go
benchmarks/*/*_go
benchmarks/*/**_go

# Rust / Kyle
benchmarks/*/*_rs
benchmarks/*/**_rs
benchmarks/*/*_ky
benchmarks/*/**_ky
benchmarks/*/*_cs
benchmarks/*/**_cs
benchmarks/*/*.class
benchmarks/*/*.dll
benchmarks/*/*.pdb
benchmarks/*/*.runtimeconfig.json
benchmarks/*/*.deps.json
benchmarks/*/bin/
benchmarks/*/obj/
benchmarks/*/*.csproj.nuget*
benchmarks/*/project.assets.json
benchmarks/*/project.nuget.cache
benchmarks/run_bench

# === Examples — only .ky source files are tracked ===
/examples/*
!/examples/*.ky
!/examples/**/*.ky
!/examples/ky.toml

