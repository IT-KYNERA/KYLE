{
  "name": "kl",
  "displayName": "Kyle Language Support",
  "description": "Kyle programming language — syntax highlighting, LSP, snippets, and language support",
  "version": "0.3.0",
  "publisher": "kynera",
  "icon": "icons/kl_128.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/IT-KYNERA/KYLE.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Debuggers",
    "Themes"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "echo 'OK'",
    "compile": "echo 'Using pre-built JS'",
    "package": "npx @vscode/vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "activationEvents": [
    "onLanguage:kl",
    "onCommand:kl.run",
    "onCommand:kl.build",
    "onCommand:kl.check",
    "onCommand:kl.test",
    "onCommand:kl.runTest",
    "onDebugInitialConfigurations",
    "onDebugResolve:kl"
  ],
  "contributes": {
    "languages": [
      {
        "id": "kl",
        "aliases": [
          "Kyle",
          "kl"
        ],
        "extensions": [
          ".kl"
        ],
        "filenames": [
          "kl.toml"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/kl.png",
          "dark": "./icons/kl.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "kl",
        "scopeName": "source.kl",
        "path": "./syntaxes/kl.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "kl.run",
        "title": "KL: Run current file"
      },
      {
        "command": "kl.build",
        "title": "KL: Build current file"
      },
      {
        "command": "kl.check",
        "title": "KL: Type-check current file"
      },
      {
        "command": "kl.test",
        "title": "KL: Run tests in current file"
      },
      {
        "command": "kl.runTest",
        "title": "KL: Run specific test"
      }
    ],
    "snippets": [
      {
        "language": "kl",
        "path": "./snippets/kl.json"
      }
    ],
    "taskDefinitions": [
      {
        "type": "kl",
        "required": ["subcommand"],
        "properties": {
          "subcommand": {
            "type": "string",
            "description": "The KL subcommand — run, build, or check"
          }
        }
      }
    ],
    "problemMatchers": [
      {
        "name": "klc",
        "label": "Kyle compiler errors",
        "owner": "kl",
        "source": "klc",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^(?:.*:)?(?:error|warning)\\[([^\\]]+)\\]:\\s*(.+)$",
          "message": 2,
          "code": 1,
          "file": 0,
          "location": 0
        }
      }
    ],
    "configuration": {
      "title": "KL",
      "properties": {
        "kl.klcPath": {
          "type": "string",
          "default": "kl",
          "description": "Path to the kl (or klc) compiler binary"
        },
        "kl.semanticHighlighting": {
          "type": "boolean",
          "default": true,
          "description": "Enable semantic highlighting for variables, types, functions, etc."
        }
      }
    },
    "debuggers": [
      {
        "type": "kl",
        "label": "Kyle Debugger",
        "languages": ["kl"],
        "program": "./out/debugger.js",
        "runtime": "node",
        "configurationAttributes": {
          "launch": {
            "required": ["program"],
            "properties": {
              "program": {
                "type": "string",
                "description": "Absolute path to a .kl file.",
                "default": "${workspaceFolder}/src/main.kl"
              },
              "klcPath": {
                "type": "string",
                "description": "Path to the kl compiler binary",
                "default": "kl"
              },
              "args": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Command line arguments passed to the program"
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "name": "KL: Launch",
            "type": "kl",
            "request": "launch",
            "program": "${workspaceFolder}/src/main.kl",
            "klcPath": "kl"
          }
        ],
        "configurationSnippets": [
          {
            "label": "KL: Launch Current File",
            "description": "Launch the currently open KL file",
            "body": {
              "name": "KL: Launch",
              "type": "kl",
              "request": "launch",
              "program": "^\"\\${file}\""
            }
          }
        ]
      }
    ],
    "themes": [
      {
        "id": "kl-color-theme",
        "label": "Kyle Pastel",
        "uiTheme": "vs-dark",
        "path": "./themes/kl-color-theme.json"
      }
    ]
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.2",
    "typescript": "^6.0.3"
  }
}
