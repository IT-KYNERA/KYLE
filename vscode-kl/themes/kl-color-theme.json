{
  "$schema": "vscode://schemas/color-theme",
  "name": "Kyle Pastel",
  "type": "dark",
  "colors": {
    "editor.background": "#1a1a2e",
    "editor.foreground": "#e0e0e0",
    "editor.lineHighlightBackground": "#16213e",
    "editor.selectionBackground": "#0f3460",
    "editorCursor.foreground": "#e94560",
    "editorWhitespace.foreground": "#3a3a5c",
    "editorLineNumber.foreground": "#4a4a6a",
    "editorLineNumber.activeForeground": "#e94560",
    "editorBracketMatch.background": "#0f3460",
    "editorBracketMatch.border": "#e94560",
    "editorGutter.background": "#1a1a2e",
    "editorWidget.background": "#16213e",
    "editorWidget.border": "#0f3460",
    "editorSuggestWidget.background": "#16213e",
    "editorSuggestWidget.border": "#0f3460",
    "editorSuggestWidget.selectedBackground": "#0f3460",
    "sideBar.background": "#12122a",
    "sideBar.foreground": "#c0c0d0",
    "sideBar.border": "#0a0a1e",
    "sideBarTitle.foreground": "#e0e0e0",
    "activityBar.background": "#0e0e24",
    "activityBar.foreground": "#e94560",
    "activityBar.border": "#0a0a1e",
    "activityBarBadge.background": "#e94560",
    "activityBarBadge.foreground": "#ffffff",
    "titleBar.activeBackground": "#0e0e24",
    "titleBar.activeForeground": "#e0e0e0",
    "statusBar.background": "#0e0e24",
    "statusBar.foreground": "#e0e0e0",
    "statusBar.debuggingBackground": "#e94560",
    "tab.activeBackground": "#1a1a2e",
    "tab.inactiveBackground": "#12122a",
    "tab.activeForeground": "#e0e0e0",
    "tab.inactiveForeground": "#6a6a8a",
    "tab.border": "#0a0a1e",
    "input.background": "#16213e",
    "input.foreground": "#e0e0e0",
    "input.border": "#0f3460",
    "list.activeSelectionBackground": "#0f3460",
    "list.inactiveSelectionBackground": "#16213e",
    "list.hoverBackground": "#16213e",
    "list.highlightForeground": "#e94560",
    "panel.background": "#1a1a2e",
    "panel.border": "#0a0a1e",
    "panelTitle.activeForeground": "#e94560",
    "terminal.background": "#1a1a2e",
    "terminal.foreground": "#e0e0e0",
    "terminal.ansiCyan": "#00d4aa",
    "terminal.ansiGreen": "#7bed9f",
    "terminal.ansiRed": "#e94560",
    "terminal.ansiYellow": "#f9ca24",
    "terminal.ansiBlue": "#70a1ff",
    "terminal.ansiMagenta": "#a29bfe",
    "scrollbarSlider.background": "#3a3a5c80",
    "scrollbarSlider.hoverBackground": "#4a4a6a80",
    "scrollbarSlider.activeBackground": "#5a5a7a80",
    "editorGroupHeader.tabsBackground": "#0e0e24",
    "editorGroup.border": "#0a0a1e",
    "dropdown.background": "#16213e",
    "dropdown.border": "#0f3460",
    "button.background": "#e94560",
    "button.foreground": "#ffffff",
    "button.hoverBackground": "#ff6b81"
  },
  "tokenColors": [
    { "scope": "comment", "settings": { "foreground": "#6a6a8a", "fontStyle": "italic" } },

    { "scope": "keyword", "settings": { "foreground": "#e94560" } },
    { "scope": "keyword.control", "settings": { "foreground": "#e94560" } },
    { "scope": "keyword.declaration.kl", "settings": { "foreground": "#e94560" } },
    { "scope": "keyword.declaration.struct.kl", "settings": { "foreground": "#e94560" } },
    { "scope": "keyword.declaration.class.kl", "settings": { "foreground": "#e94560" } },
    { "scope": "keyword.declaration.enum.kl", "settings": { "foreground": "#e94560" } },
    { "scope": "keyword.declaration.contract.kl", "settings": { "foreground": "#e94560" } },
    { "scope": "keyword.declaration.import.kl", "settings": { "foreground": "#e94560" } },
    { "scope": "keyword.declaration.from.kl", "settings": { "foreground": "#e94560" } },
    { "scope": "keyword.declaration.as.kl", "settings": { "foreground": "#e94560" } },
    { "scope": "keyword.declaration.type.kl", "settings": { "foreground": "#e94560" } },
    { "scope": "keyword.declaration.new.kl", "settings": { "foreground": "#e94560" } },
    { "scope": "keyword.operator.kl", "settings": { "foreground": "#f8a5c2" } },
    { "scope": "keyword.operator.inheritance.kl", "settings": { "foreground": "#f8a5c2", "fontStyle": "bold" } },

    { "scope": "storage.type.kl", "settings": { "foreground": "#00d4aa", "fontStyle": "bold" } },
    { "scope": "storage.type.optional.kl", "settings": { "foreground": "#00d4aa" } },
    { "scope": "storage.type.error.kl", "settings": { "foreground": "#ff6b81" } },
    { "scope": "storage.modifier.kl", "settings": { "foreground": "#e94560", "fontStyle": "italic" } },

    { "scope": "constant.language.kl", "settings": { "foreground": "#f9ca24", "fontStyle": "bold" } },
    { "scope": "constant.numeric.kl", "settings": { "foreground": "#f9ca24" } },
    { "scope": "variable.other.constant.kl", "settings": { "foreground": "#f9ca24" } },

    { "scope": "string.quoted.double.kl", "settings": { "foreground": "#7bed9f" } },
    { "scope": "string.quoted.single.kl", "settings": { "foreground": "#7bed9f" } },
    { "scope": "string.interpolated.kl", "settings": { "foreground": "#7bed9f" } },
    { "scope": "constant.character.escape.kl", "settings": { "foreground": "#f9ca24", "fontStyle": "bold" } },

    { "scope": "entity.name.function.kl", "settings": { "foreground": "#70a1ff" } },
    { "scope": "support.function.kl", "settings": { "foreground": "#00d4aa" } },
    { "scope": "entity.name.type.kl", "settings": { "foreground": "#a29bfe", "fontStyle": "bold" } },

    { "scope": "variable.other.kl", "settings": { "foreground": "#e0e0e0" } },
    { "scope": "variable.other.mutable.kl", "settings": { "foreground": "#e0e0e0", "fontStyle": "underline" } },
    { "scope": "variable.other.property.kl", "settings": { "foreground": "#70a1ff" } },
    { "scope": "variable.language.kl", "settings": { "foreground": "#e94560", "fontStyle": "italic" } },
    { "scope": "variable.parameter.kl", "settings": { "foreground": "#f8a5c2" } },

    { "scope": "string.unquoted.import-path.kl", "settings": { "foreground": "#7bed9f" } },
    { "scope": "meta.annotation.kl", "settings": { "foreground": "#7bed9f", "fontStyle": "bold" } },

    { "scope": "punctuation.bracket.kl", "settings": { "foreground": "#c0c0d0" } },
    { "scope": "punctuation.bracket.round.kl", "settings": { "foreground": "#c0c0d0" } },
    { "scope": "punctuation.separator.kl", "settings": { "foreground": "#c0c0d0" } },
    { "scope": "punctuation.separator.colon.kl", "settings": { "foreground": "#c0c0d0" } },

    { "scope": "invalid", "settings": { "foreground": "#e94560", "background": "#2a0a1e" } }
  ]
}
