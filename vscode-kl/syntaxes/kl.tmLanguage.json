{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "KL",
  "scopeName": "source.kl",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#builtins" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.number-sign.kl", "match": "#.*$" }
      ]
    },
    "strings": {
      "name": "string.quoted.double.kl",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "name": "constant.character.escape.kl", "match": "\\\\." }
      ]
    },
    "numbers": {
      "name": "constant.numeric.kl",
      "match": "\\b(0[xX][0-9a-fA-F_]+|0[bB][01_]+|\\d[\\d_]*(\\.\\d[\\d_]*)?)\\b"
    },
    "keywords": {
      "patterns": [
        { "name": "keyword.control.kl", "match": "\\b(if|elif|else|while|for|in|match|return|break|continue|loop|defer|guard|unsafe|async|await)\\b" },
        { "name": "keyword.declaration.kl", "match": "\\b(fn|mut|class|struct|enum|contract|import|from|as|type|abs|const|pub|override|static|abstract|impl)\\b" },
        { "name": "keyword.operator.kl", "match": "\\b(and|or|not)\\b" },
        { "name": "keyword.other.kl", "match": "\\b(true|false|None|ok|error|this|next)\\b" }
      ]
    },
    "types": {
      "name": "storage.type.kl",
      "match": "\\b(i32|i64|f32|f64|bool|str|char|void|Option|Result|any|list)\\b"
    },
    "builtins": {
      "name": "support.function.kl",
      "match": "\\b(print|println|str|len|int|float|bool|input|open|read_str|write_str|close|sleep|now|contains|to_upper|to_lower|trim|replace|substr|char_at|ord|is_digit|is_alpha|is_alnum|is_whitespace|is_upper|is_lower|assert|assert_eq|assert_str|range)\\b"
    },
    "operators": {
      "name": "keyword.operator.kl",
      "match": "(==|!=|<=|>=|&&|\\|\\||\\+\\+|--|->|=>|\\?|\\.\\.|\\+%|-%|\\*%|\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|<<=|>>=|<<|>>|\\+|-|\\*|/|%|&|\\||\\^|~|=|<|>|!)"
    }
  }
}
