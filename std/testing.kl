fn assert(condition: bool):
    if !condition:
        println("Assertion failed!")

fn assert_eq(a: i32, b: i32):
    if a != b:
        print("Assertion failed: ")
        print(str(a))
        print(" != ")
        println(str(b))

fn assert_str(a: str, b: str):
    if a != b:
        println("Assertion failed: strings differ")
