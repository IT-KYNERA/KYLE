fn assert(condition: bool):
    if !condition:
        println("ASSERTION FAILED")

fn assert_eq(a: i32, b: i32):
    if a != b:
        println("ASSERTION FAILED: expected ")
        println(a)
        println(" but got ")
        println(b)

fn assert_str(a: str, b: str):
    if a != b:
        println("ASSERTION FAILED: expected ")
        print(a)
        println(" but got ")
        print(b)

fn assert_ne(a: i32, b: i32):
    if a == b:
        println("ASSERTION FAILED: expected not equal")
        println(a)
