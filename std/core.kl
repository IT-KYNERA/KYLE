enum Option<T>:
    None
    Some(T)

fn unwrap_or<T>(opt: T?, default: T) T:
    match opt:
        v:
            v
        none:
            default

fn is_some<T>(opt: T?) bool:
    match opt:
        v:
            true
        none:
            false

fn is_none<T>(opt: T?) bool:
    match opt:
        v:
            false
        none:
            true
