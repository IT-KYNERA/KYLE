# json package tests
from packages.json.src.lib import parse, stringify

#[test]
fn test_json_parse():
    data = parse("{\"name\": \"Kyle\", \"version\": 1}")
    assert(data["version"] == 1)
    assert(data["name"] == "Kyle")

#[test]
fn test_json_stringify():
    d = { "name": "Kyle", "version": 1 }
    json_str = stringify(d)
    assert(json_str != "")
