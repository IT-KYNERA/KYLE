# {{project_name}} — entry point
view("/")

@(
    count: ^i32 = 0
    fn increment():
        count = count + 1
)

<app>
    <view padding=20>
        <column layout=center spacing=16>
            <text value="Bienvenido a Kyle UI!" font_size=24 font_weight=Bold />
            <text value="Contador: 0" />
            <button tpl=Primary text="+" click=@increment />
        </column>
    </view>
</app>
