extern fn LLVMPrintModuleToString(mod: ptr) ptr
extern fn LLVMDisposeMessage(msg: ptr)

# ═══════════════════════════════════════════════════════════════
# Wrappers Kyle (opcionales, para uso desde Kyle)
# ═══════════════════════════════════════════════════════════════

fn create_module(name: &str) ptr:
    return LLVMModuleCreateWithName(ky_ptr_read_ptr(name as ptr))

fn i32_type() ptr:
    return LLVMInt32Type()

fn i64_type() ptr:
    return LLVMInt64Type()

fn void_type() ptr:
    return LLVMVoidType()

fn ptr_type() ptr:
    return LLVMPointerType(LLVMInt8Type(), 0)

fn fn_type(ret: ptr, params: ptr, count: i32, variadic: i32) ptr:
    return LLVMFunctionType(ret, params, count, variadic)

fn add_fn(mod: ptr, name: &str, ft: ptr) ptr:
    return LLVMAddFunction(mod, ky_ptr_read_ptr(name as ptr), ft)

fn build_ret_void(builder: ptr):
    LLVMBuildRetVoid(builder)

fn print_module(mod: ptr) str:
    msg = LLVMPrintModuleToString(mod)
    if msg == 0 as ptr:
        return ""
    s: ptr = msg
    result = s as str
    LLVMDisposeMessage(msg)
    return result

# ═══════════════════════════════════════════════════════════════
# Test: generate a minimal LLVM IR module
# ═══════════════════════════════════════════════════════════════

fn test_minimal():
    mod = create_module(&"test")
    i32 = i32_type()
    ret_type = fn_type(void_type(), 0 as ptr, 0, 0)
    fn_val = add_fn(mod, &"main", ret_type)
    entry = LLVMAppendBasicBlock(fn_val, &"entry")
    builder = LLVMCreateBuilder()
    LLVMPositionBuilderAtEnd(builder, entry)
    build_ret_void(builder)
    ir = print_module(mod)
    if ir != "":
        print("=== LLVM IR ===")
        print(ir)
    LLVMDisposeModule(mod)

fn main():
    test_minimal()
