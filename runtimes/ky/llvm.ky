# LLVM C API bindings — Kyle wrappers para libLLVM
# Permite que el codegen Kyle genere LLVM IR y binarios.
# ~150 extern fn esenciales, mismo patron que packages/http/

# ─── Module ─────────────────────────────────────────────────

@link "llvm"
extern fn LLVMModuleCreateWithName(name: ptr) ptr
extern fn LLVMDisposeModule(mod: ptr)
extern fn LLVMGetModuleIdentifier(mod: ptr, len: ptr) ptr
extern fn LLVMSetModuleIdentifier(mod: ptr, name: ptr, len: i64)

