fn main(args: [str]) -> i32:
    # Ternary operator: cond ? then : else
    age = 18
    status = age >= 18 ? "Adult" : "Minor"
    println(status)

    # Integer ternary
    x = 5 == 5 ? 42 : 0
    println(x)

    # Nested ternary (right-associative)
    z = 1 == 1 ? 2 == 2 ? 3 : 4 : 5
    println(z)
    0
