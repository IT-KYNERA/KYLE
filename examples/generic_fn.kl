struct Pair<T, U>:
    first: T
    second: U

fn make_pair<T, U>(a: T, b: U) -> Pair<T, U>:
    return Pair { first: a, second: b }

fn first<T>(items: list<T>) -> T:
    return items[0]

fn main():
    p = make_pair(1, "hello")
    println(p.first)
    println(p.second)
    x = first([10, 20, 30])
    y = first(["a", "b", "c"])
    println(x)
    println(y)
