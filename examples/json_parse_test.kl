fn main() -> i32:
    data = json_parse("\{ \"count\" : 42 \}")
    if data != 0:
        val = data["count"]
        println(val)
        result = json_stringify(data)
        if contains(result, "\"count\":42"):
            println("PASS")
            0
        else:
            println("FAIL: wrong value")
            1
    else:
        println("FAIL: null parse")
        1
