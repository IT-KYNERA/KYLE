import math
import str
import collections
import time
import core

fn main():
    # Test math module
    println("Math:")
    println(absolute(-5))
    println(pow(2, 10))
    println(gcd(12, 8))
    println(min(10, 20))
    println(max(10, 20))
    println(clamp(100, 0, 50))
    # Test str module
    println("Str:")
    println(capitalize("hello"))
    println(repeat_str("ab", 3))
    println(starts_with_str("hello", "he"))
    println(ends_with_str("world", "ld"))
    # Test collections module
    println("Collections:")
    println(list_sum([1, 2, 3, 4, 5]))
    println(list_product([1, 2, 3, 4]))
    println(list_max([3, 7, 2, 9]))
    println(list_min([3, 7, 2, 9]))
    # Test time module
    println("Time:")
    t = timestamp()
    println(t)
    sleep_ms(10)
    # Test core module
    println("Core:")
    mut v = Option.Some(42)
    println(is_some(v))
    println(is_none(v))
    v2 = unwrap_or(v, 0)
    println(v2)
