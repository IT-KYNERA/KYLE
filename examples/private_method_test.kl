# Test: private method visibility.
# - `__secret` declarado privado
# - `this.secret()` dentro de la clase → OK
# - `p.secret()` fuera de la clase → ERROR

fn main(args: [str]) -> i32:
    p = Counter()
    p.run()
    # p.secret()  ← este no debe compilar porque es privado
    return 0

class Counter:
    fn __secret():
        println("private secret")
    fn run():
        # acceso via `this` → permitido (privado es visible dentro)
        this.secret()
        println("public, called this.secret() inside run()")