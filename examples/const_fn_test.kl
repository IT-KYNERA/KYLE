const fn add(a: i32, b: i32) -> i32:
    a + b

const fn factorial(n: i32) -> i32:
    if n <= 1:
        1
    else:
        n * factorial(n - 1)

const fn square(x: i32) -> i32:
    x * x

fn main(args: [str]) -> i32:
    result = add(3, 4)
    println(result)

    fac = factorial(5)
    println(fac)

    sq = square(9)
    println(sq)
    0
