enum Option<T>:
    None
    Some(T)

struct Person:
    age: i32

fn test_some():
    mut p = Person { age: 25 }
    mut opt = Option.Some(p)
    result = opt?.age
    mut val = 0
    match result:
        Option.Some(v):
            val = v
        Option.None:
            val = -1
    if val == 25:
        println("PASS: ?. with Some")
    else:
        println("FAIL: ?. with Some expected 25 got ")
        println(val)

fn test_none():
    mut opt = Option.None
    result = opt?.age
    mut val = 0
    match result:
        Option.Some(v):
            val = v
        Option.None:
            val = -1
    if val == -1:
        println("PASS: ?. with None")
    else:
        println("FAIL: ?. with None expected -1 got ")
        println(val)

fn main(args: [str]) -> i32:
    test_some()
    test_none()
    println("ALL PASS")
    0
