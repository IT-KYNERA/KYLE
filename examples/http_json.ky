# HTTP + JSON example — fetch posts from JSONPlaceholder
# Run: ky run examples/http_json.ky

@link "curl"

extern fn system(cmd: ptr) i32

ZERO := 48

fn parse_int(s: str) i32:
    result: &i32 = 0
    i: &i32 = 0
    while i < len(s):
        c = char_at(s, i)
        if c >= ZERO and c <= 57:
            result = result * 10 + (c - ZERO)
        i = i + 1
    result

fn main() i32:
    # ── GET /posts ──
    system("curl -s -o /tmp/ky_body.txt -w '%\{http_code\}' 'https://jsonplaceholder.typicode.com/posts' > /tmp/ky_status.txt 2>/dev/null" as ptr)

    fd = open("/tmp/ky_status.txt", 0)
    status_str = ""
    if fd >= 0:
        status_str = read_str(fd, 32)
        close(fd)
    status = parse_int(status_str)
    println("GET /posts -> status: {status}")

    bd = open("/tmp/ky_body.txt", 0)
    body = ""
    if bd >= 0:
        body = read_str(bd, 50000)
        close(bd)

    println("Response body length: {len(body)} chars")

    # ── GET /posts/1 (single post) ──
    system("curl -s -o /tmp/ky_body.txt -w '%\{http_code\}' 'https://jsonplaceholder.typicode.com/posts/1' > /tmp/ky_status.txt 2>/dev/null" as ptr)

    fd2 = open("/tmp/ky_status.txt", 0)
    if fd2 >= 0:
        status_str = read_str(fd2, 32)
        close(fd2)
    status2 = parse_int(status_str)
    println("\nGET /posts/1 -> status: {status2}")

    bd2 = open("/tmp/ky_body.txt", 0)
    body2 = ""
    if bd2 >= 0:
        body2 = read_str(bd2, 2000)
        close(bd2)
    println(body2)

    # Count posts (count commas between objects)
    count: &i32 = 1
    i: &i32 = 0
    while i < len(body):
        if char_at(body, i) == 123: # {
            count = count + 1
        i = i + 1
    println("Number of posts returned: {count}")

    0
