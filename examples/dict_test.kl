# dict_test.kl — Dictionary literal + indexing + assignment end-to-end

fn main():
    # Dict literal with i32 values
    d = {"alice": 25, "bob": 30, "charlie": 35}

    # Index access
    println("alice: ")
    println(d["alice"])

    # Assignment
    d["bob"] = 31
    println("bob after set: ")
    println(d["bob"])

    # Dict length
    println("len: ")
    println(d.len())

    # Dict with str values
    names = {"a": "Alice", "b": "Bob", "c": "Charlie"}
    println(names["a"])
    println(names["c"])

    println("dict test passed")
