enum Option<T>:
    None
    Some(T)

fn test_option() -> i32:
    mut x = Option.Some(42)
    result = 0
    match x:
        Option.Some(v):
            result = v
        Option.None:
            result = -1
    result

fn main(args: [str]) -> i32:
    result = test_option()
    println("result = ")
    println(result)
    if result == 42:
        println("PASS")
        0
    else:
        println("FAIL")
        1
