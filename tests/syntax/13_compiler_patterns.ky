# Patrones usados en el compilador (parser, type checker, MIR)

# --- Scope chain (type checker) ---
final class Scope:
    parent: Scope?
    symbols: ^{str: i32}

fn lookup(s: Scope, name: &str) i32?:
    if s.symbols.has(name):
        return some(s.symbols.get(name))
    if s.parent:
        return lookup(s.parent, &name)
    return none

# --- Basic block graph (MIR) ---
final class BasicBlock:
    id: i32
    successors: ^{i32}

fn add_successor(block: ^BasicBlock, target: i32):
    block.successors.push(target)

# --- Sum list (MIR traversal) ---
fn sum_items(items: &{i32}) i32:
    total: ^i32 = 0
    for item in items:
        total += item
    return total

# --- Token classification ---
fn classify(name: &str) str:
    if name == "fn" or name == "if" or name == "while":
        return "keyword"
    elif name == "i32" or name == "str" or name == "bool":
        return "type"
    elif name.starts_with("ky_"):
        return "runtime"
    else:
        return "identifier"

# --- String join ---
fn join(items: &{str}, sep: &str) str:
    result = ""
    first = true
    for item in items:
        if first:
            result = item
            first = false
        else:
            result = result + sep + item
    return result

fn main():
    s = Scope{parent: none, symbols: {}}
    n = "test"
    _ = lookup(s, &n)
    items = {"a", "b", "c"}
    result = join(&items, &", ")
    print(result)
    tok = "fn"
    print(classify(&tok))
    nums: ^{i32} = {1, 2, 3}
    print(sum_items(&nums).to_str())
