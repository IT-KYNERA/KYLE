# Colecciones — listas, dicts

fn test_lists():
    items: ^{i32} = {10, 20, 30}
    items.push(40)
    first = items[0]
    items[0] = 99
    len = items.len()
    popped = items.pop()

fn test_dicts():
    scores: ^{str: i32} = {}
    scores.set("ana", 100)
    scores.set("bob", 85)
    if scores.has("ana"):
        val = scores.get("ana")
    scores.remove("bob")

fn main():
    test_lists()
    test_dicts()
