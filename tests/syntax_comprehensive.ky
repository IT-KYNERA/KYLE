# --- Compound assignment ---
fn test_compound_assign():
    count: ^i32 = 0
    count += 1
    count -= 1
    count *= 2
    count /= 2
    count %= 2

# --- While loop ---
fn test_while():
    i: ^i32 = 0
    while i < 10:
        i += 1

# --- For-else ---
fn test_for_else():
    items = {1, 2, 3}
    for item in items:
        if item == 99:
            print("found")
            break
    else:
        print("not found")

# --- Break/continue ---
fn test_break_continue():
    for i in 0..10:
        if i % 2 == 0: continue
        if i > 7: break
        print(i)

# --- Defer ---
fn test_defer():
    f = ky_open("/tmp/test", "w")
    defer ky_close(f)
    ky_write_str(f, "data")

# --- Guard ---
fn test_guard(val: i32?) i32:
    guard val else: return 0
    return val

# --- Option/Result operations ---
fn test_optional():
    x: i32? = none
    if x:
        print(x)

    y: i32? = 42
    if y:
        val = y
        print(val)

# --- Null-coalescing ---
fn test_null_coalescing():
    name: str? = none
    display = name ?? "anonymous"

# --- Operator overloading ---
final class Vec2:
    x: f64
    y: f64

    fn op_add(this, other: Vec2) Vec2:
        return Vec2(x: this.x + other.x, y: this.y + other.y)

    fn op_sub(this, other: Vec2) Vec2:
        return Vec2(x: this.x - other.x, y: this.y - other.y)

    fn op_eq(this, other: Vec2) bool:
        return this.x == other.x and this.y == other.y

# --- Tuple destructuring ---
fn test_tuples():
    pair = (1, "hello")
    a, b = pair
    print(a.to_str() + b)

    fn divmod(a: i32, b: i32) (i32, i32):
        return (a / b, a % b)
    q, r = divmod(10, 3)

