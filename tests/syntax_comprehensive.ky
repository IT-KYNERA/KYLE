# ═══════════════════════════════════════════════════════════════
# NIVEL 1: Parser (kyc_frontend) — strings, match, chars, list
# ═══════════════════════════════════════════════════════════════

# --- Strings (el parser trabaja con caracteres todo el tiempo) ---
fn test_strings():
    s = "hello world"
    len = s.len()
    c = s.char_at(0)        # 'h'
    upper = s.upper()
    lower = s.lower()
    contains = s.contains("hello")
    trimmed = s.trim()
    replaced = s.replace("world", "kyle")
    substr = s.substr(0, 5) # "hello"
    first = s[0]            # indexing (maybe not supported)

fn test_string_interpolation():
    name = "Kyle"
    msg = "Hello, {name}!"
    calc = "2+2 = {2 + 2}"
    multi = """
line 1
line 2
"""

# --- Character operations (critical for lexer) ---
fn test_chars():
    s = "Hello"
    for c in s:
        is_digit = ky_is_digit(c)
        is_alpha = ky_is_alpha(c)
        is_alnum = ky_is_alnum(c)
        is_space = ky_is_whitespace(c)
        is_upper = ky_is_upper(c)
        is_lower = ky_is_lower(c)

# --- Pattern matching (parser usa match constantemente) ---
enum TokenKind:
    Ident(name: str)
    Number(val: i64)
    String(val: str)
    LParen
    RParen
    Comma
    Plus
    Minus
    Star
    Slash
    EOF

fn token_name(t: TokenKind) str:
    match t:
        TokenKind.Ident(n): n
        TokenKind.Number(v): v.to_str()
        TokenKind.String(v): v
        TokenKind.LParen: "("
        TokenKind.RParen: ")"
        TokenKind.Comma: ","
        TokenKind.Plus: "+"
        TokenKind.Minus: "-"
        TokenKind.Star: "*"
        TokenKind.Slash: "/"
        TokenKind.EOF: "EOF"

fn is_binary_op(t: TokenKind) bool:
    match t:
        TokenKind.Plus: true
        TokenKind.Minus: true
        TokenKind.Star: true
        TokenKind.Slash: true
        _: false

# --- Match como expresion ---
fn op_precedence(t: TokenKind) i32:
    match t:
        TokenKind.Plus | TokenKind.Minus: 1
        TokenKind.Star | TokenKind.Slash: 2
        _: 0

# --- Match con guardias ---
fn describe_number(n: i32) str:
    match n:
        m if m < 0: "negative"
        0: "zero"
        m if m < 10: "small"
        _: "large"

# --- Lists (parser las usa para todo) ---
fn test_lists():
    items: ^[i32] = []     # mutable list
    items.push(1)
    items.push(2)
    items.push(3)
    first = items[0]
    items[0] = 99
    len = items.len()
    popped = items.pop()
    contains = items.contains(99)

    # Iteracion
    for item in items:
        print(item)

    # map/filter/fold
    doubled = items.map(fn(x): x * 2)
    evens = items.filter(fn(x): x % 2 == 0)
    sum = items.fold(0, fn(acc, x): acc + x)

# --- Dicts (scopes, type environments) ---
fn test_dicts():
    env: ^{str: i32} = {}
    env.set("x", 10)
    env.set("y", 20)
    if env.has("x"):
        val = env.get("x")
    env.remove("y")

    # Type environment para type checker
    type_env: ^{str: str} = {}
    type_env.set("x", "i32")
    type_env.set("y", "str")
    type_env.set("add", "fn(i32, i32) i32")

# --- Enums con payload (AST nodes) ---
enum Expr:
    IntLiteral(val: i64)
    StrLiteral(val: str)
    Ident(name: str)
    BinaryOp(left: box Expr?, op: TokenKind, right: box Expr?)
    Call(callee: box Expr?, args: ^{Expr})
    If(cond: box Expr?, then: box Expr?, else_: box Expr?)

enum Stmt:
    Let(name: str, type_annot: str?, value: Expr?)
    If(cond: Expr, then: ^{Stmt}, else_: ^{Stmt}?)
    While(cond: Expr, body: ^{Stmt})
    Return(val: Expr?)
    ExprStmt(expr: Expr)

# --- Recursion (parser es recursivo) ---
fn fib(n: i32) i32:
    if n <= 1: return n
    return fib(n - 1) + fib(n - 2)

fn parse_expr(tokens: &[TokenKind], pos: ^i32) Expr:
    token = tokens[pos.get()]
    pos.set(pos.get() + 1)
    match token:
        TokenKind.Number(v): Expr.IntLiteral(val: v)
        TokenKind.Ident(n): Expr.Ident(name: n)
        _: Expr.IntLiteral(val: 0)

# --- Option T? (parser ops returning optional) ---
fn peek_token(tokens: &[TokenKind], pos: i32) TokenKind?:
    if pos < tokens.len():
        return tokens[pos]
    return none

fn expect_token(tokens: &[TokenKind], pos: ^i32, kind: TokenKind) bool:
    token = peek_token(tokens, pos.get())
    match token:
        t: if t == kind:
            pos.set(pos.get() + 1)
            return true
        none: return false

# --- Result T! (fallible operations) ---
fn safe_divide(a: i32, b: i32) i32!:
    if b == 0:
        return error("division by zero")
    return ok(a / b)

fn parse_number(s: &str) i64!:
    val = ky_str_to_i64(ky_ptr_read_ptr(s as ptr))
    if val == 0 and s != "0":
        return error("invalid number")
    return ok(val)

# ═══════════════════════════════════════════════════════════════
# NIVEL 2: Type Checker (kyc_semantic) — tipos, scopes, generics
# ═══════════════════════════════════════════════════════════════

# --- Clases (tipos compuestos) ---
final class Type:
    name: str
    kind: TypeKind

enum TypeKind:
    Primitive(name: str)
    Function(params: ^{Type}, ret: box Type?)
    List(elem: box Type?)
    Dict(key: box Type?, val: box Type?)
    Optional(inner: box Type?)
    Named(name: str, params: ^{Type})

final class Scope:
    parent: Scope?
    symbols: ^{str: Type}

fn scope_lookup(scope: Scope, name: &str) Type?:
    if scope.symbols.has(name):
        return scope.symbols.get(name)
    match scope.parent:
        p: return scope_lookup(p, name)
        none: return none

fn scope_declare(scope: ^Scope, name: str, type: Type):
    scope.symbols.set(name, type)

# --- Genericos ---
final class Box<T>:
    value: T

    fn get(self) T:
        return self.value

final class Pair<A, B>:
    first: A
    second: B

# --- Funciones como tipo ---
final class FunctionType:
    params: ^{Type}
    return_type: Type
    is_fallible: bool

    fn matches(self, arg_types: ^{Type}) bool:
        if self.params.len() != arg_types.len():
            return false
        for i in 0..self.params.len():
            if self.params[i] != arg_types[i]:
                return false
        return true

# --- Sets (para tracking, analisis) ---
fn test_sets():
    used_names: ^set<str> = set()
    used_names.add("x")
    used_names.add("y")
    if used_names.contains("x"):
        used_names.remove("x")

# ═══════════════════════════════════════════════════════════════
# NIVEL 3: MIR (kyc_mir) — basic blocks, grafos, optimizaciones
# ═══════════════════════════════════════════════════════════════

# --- Basic blocks (grafo de control flow) ---
final class BasicBlock:
    id: i32
    instructions: ^{Inst}
    terminator: Terminator?

enum Terminator:
    Return(val: i64?)
    Branch(target: i32)
    CondBranch(cond: i64, true_target: i32, false_target: i32)

enum Inst:
    Alloca(name: str, type: Type)
    Store(name: str, val: i64)
    Load(dest: str, source: str)
    Call(dest: str?, fn_name: str, args: ^{i64})
    BinaryOp(dest: str, op: BinaryOp, lhs: i64, rhs: i64)

enum BinaryOp:
    Add
    Sub
    Mul
    Div
    Eq
    Ne
    Lt
    Gt

# --- Grafo de control flow ---
final class CFGGraph:
    blocks: ^{BasicBlock}
    entry: BasicBlock?

fn cfg_add_block(graph: ^CFGGraph, block: BasicBlock):
    graph.blocks.push(block)
    if graph.entry == none:
        graph.entry = block

fn cfg_successors(block: BasicBlock) ^{i32}:
    result: ^{i32} = {}
    match block.terminator:
        Terminator.Branch(target): result.push(target)
        Terminator.CondBranch(cond, t, f):
            result.push(t)
            result.push(f)
        _: none
    return result

# --- Algoritmo de dominadores (MIR usa esto) ---
fn find_dominators(cfg: &CFGGraph) ^{i32}:
    dom: ^{i32} = {}
    return dom

