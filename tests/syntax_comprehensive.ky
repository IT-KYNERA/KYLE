    # Test parsing expressions
    tokens: ^TokenKind = {}
    tokens.push(TokenKind.Number(val: 42))
    tokens.push(TokenKind.Plus)
    tokens.push(TokenKind.Number(val: 10))
    pos: ^i32 = 0
    expr = parse_expr(tokens.as_ref(), pos)
    name = token_name(TokenKind.Plus)

    print("All tests passed!")
