{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "KL",
  "scopeName": "source.ky",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#char_literals" },
    { "include": "#numbers" },
    { "include": "#attributes" },
    { "include": "#class_def" },
    { "include": "#enum_def" },
    { "include": "#contract_def" },
    { "include": "#type_alias" },
    { "include": "#function_def" },
    { "include": "#import_path" },
    { "include": "#constructor_call" },
    { "include": "#keywords_control" },
    { "include": "#keywords_declaration" },
    { "include": "#keywords_operator" },
    { "include": "#keywords_other" },
    { "include": "#types_primitive" },
    { "include": "#types_special" },
    { "include": "#builtins" },
    { "include": "#constants" },
    { "include": "#operators" },
    { "include": "#variable_decl" },
    { "include": "#property_access" },
    { "include": "#mutable_var" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-number-sign.ky", "match": "##.*$" },
        { "name": "comment.line.number-sign.ky", "match": "#[^#].*$|#$" }
      ]
    },
    "strings": {
      "name": "string.quoted.double.ky",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "name": "constant.character.escape.ky", "match": "\\\\[nrt0\"'\\\\]" },
        { "name": "constant.character.escape.ky", "match": "\\\\x[0-9a-fA-F]{2}" },
        { "name": "constant.character.escape.ky", "match": "\\\\u[0-9a-fA-F]{4}" },
        { "include": "#interpolation" }
      ]
    },
    "interpolation": {
      "name": "string.interpolated.ky",
      "begin": "\\{",
      "end": "\\}",
      "patterns": [{ "include": "#expression" }]
    },
    "expression": {
      "patterns": [
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#keywords_control" },
        { "include": "#types_primitive" },
        { "include": "#operators" }
      ]
    },
    "char_literals": {
      "name": "string.quoted.single.ky",
      "begin": "'",
      "end": "'",
      "patterns": [
        { "name": "constant.character.escape.ky", "match": "\\\\[nrt0\"'\\\\]" },
        { "name": "constant.character.escape.ky", "match": "\\\\x[0-9a-fA-F]{2}" }
      ]
    },
    "numbers": {
      "name": "constant.numeric.ky",
      "match": "\\b(0[xX][0-9a-fA-F_]+|0[bB][01_]+|\\d[\\d_]*(\\.\\d[\\d_]*)?([eE][+-]?\\d+)?)\\b"
    },
    "keywords_control": {
      "name": "keyword.control.ky",
      "match": "\\b(if|elif|else|while|for|in|match|return|break|continue|loop|defer|guard|unsafe|async|await|pass)\\b"
    },
    "keywords_declaration": {
      "patterns": [
        { "name": "keyword.declaration.struct.ky", "match": "\\bfinal\\s+class\\b" },
        { "name": "keyword.declaration.class.ky", "match": "\\babstract\\s+class\\b" },
        { "name": "keyword.declaration.enum.ky", "match": "\\bstruct\\b" },
        { "name": "keyword.declaration.contract.ky", "match": "\\bcontract\\b" },
        { "name": "keyword.declaration.import.ky", "match": "\\bimport\\b" },
        { "name": "keyword.declaration.from.ky", "match": "\\bfrom\\b" },
        { "name": "keyword.declaration.as.ky", "match": "\\bas\\b" },
        { "name": "keyword.declaration.type.ky", "match": "\\btype\\b" },
        { "name": "keyword.declaration.new.ky", "match": "\\bnew\\b" },
        { "name": "storage.modifier.ky", "match": "\\b(static|override|const|abstract)\\b" }
      ]
    },
    "keywords_operator": {
      "name": "keyword.operator.ky",
      "match": "\\b(and|or|not|is)\\b"
    },
    "keywords_other": {
      "patterns": [
        { "name": "constant.language.ky", "match": "\\b(true|false|None|null)\\b" },
        { "name": "variable.language.ky", "match": "\\b(this|super)\\b" }
      ]
    },
    "types_primitive": {
      "name": "storage.type.ky",
      "match": "\\b(i32|i64|f32|f64|bool|str|char|void|any|ptr)\\b"
    },
    "types_special": {
      "patterns": [
        { "name": "storage.type.optional.ky", "match": "\\b([A-Z][a-zA-Z0-9_]*)\\?\\b" },
        { "name": "storage.type.error.ky", "match": "\\b([A-Z][a-zA-Z0-9_]*)\\!\\b" }
      ]
    },
    "builtins": {
      "name": "support.function.ky",
      "match": "\\b(print|println|print_err|len|int|float|bool|assert|assert_eq|assert_ne|range|clone)\\b"
    },
    "constants": {
      "name": "variable.other.constant.ky",
      "match": "\\b[A-Z][A-Z0-9_]{2,}\\b"
    },
    "operators": {
      "name": "keyword.operator.ky",
      "patterns": [
        { "match": "::" },
        { "match": ":=" },
        { "match": "(\\.\\.<|\\.\\.=|\\.\\.\\.|\\.\\.)" },
        { "match": "(==|!=|<=|>=|->|=>|\\?|\\|)" },
        { "match": "(\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|<<=|>>=)" },
        { "match": "(<<|>>)" },
        { "match": "(&&|\\|\\|)" },
        { "match": "(\\+|-|\\*|/|%|&|\\^|~|=|<|>|!)" }
      ]
    },
    "class_def": {
      "patterns": [
        {
          "begin": "\\b(final\\s+class|abstract\\s+class|class)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "beginCaptures": {
            "1": { "name": "keyword.declaration.ky" },
            "2": { "name": "entity.name.type.ky" }
          },
          "end": "(?=:|\n)",
          "patterns": [
            { "include": "#types_primitive" },
            { "match": "::", "name": "keyword.operator.inheritance.ky" },
            { "match": "<", "name": "punctuation.bracket.ky" },
            { "match": ">", "name": "punctuation.bracket.ky" },
            { "match": ",", "name": "punctuation.separator.ky" },
            { "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\b", "name": "entity.name.type.ky" }
          ]
        }
      ]
    },
    "enum_def": {
      "patterns": [
        {
          "begin": "\\b(enum)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "beginCaptures": {
            "1": { "name": "keyword.declaration.ky" },
            "2": { "name": "entity.name.type.ky" }
          },
          "end": "(?=:|\n)",
          "patterns": [
            { "match": "<", "name": "punctuation.bracket.ky" },
            { "match": ">", "name": "punctuation.bracket.ky" }
          ]
        }
      ]
    },
    "contract_def": {
      "patterns": [
        {
          "begin": "\\b(contract)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "beginCaptures": {
            "1": { "name": "keyword.declaration.ky" },
            "2": { "name": "entity.name.type.ky" }
          },
          "end": "(?=:|\n)"
        }
      ]
    },
    "type_alias": {
      "patterns": [
        {
          "begin": "\\b(type)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "beginCaptures": {
            "1": { "name": "keyword.declaration.ky" },
            "2": { "name": "entity.name.type.ky" }
          },
          "end": "(?=\n)"
        }
      ]
    },
    "function_def": {
      "patterns": [
        {
          "begin": "(?:(const|async|abstract)\\s+)?(fn)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "beginCaptures": {
            "1": { "name": "storage.modifier.ky" },
            "2": { "name": "keyword.declaration.ky" },
            "3": { "name": "entity.name.function.ky" }
          },
          "end": "(?=:|\n|{)",
          "patterns": [
            { "include": "#types_primitive" },
            { "include": "#types_special" },
            { "match": "<", "name": "punctuation.bracket.ky" },
            { "match": ">", "name": "punctuation.bracket.ky" },
            { "match": ",", "name": "punctuation.separator.ky" },
            { "match": "\\(", "name": "punctuation.bracket.round.ky" },
            { "match": "\\)", "name": "punctuation.bracket.round.ky" },
            { "match": "\\b([a-z_][a-zA-Z0-9_]*)(?=\\s*:)", "name": "variable.parameter.ky" },
            { "match": ":", "name": "punctuation.separator.colon.ky" }
          ]
        }
      ]
    },
    "import_path": {
      "patterns": [
        { "name": "string.unquoted.import-path.ky", "match": "(?<=\\b(?:import|from)\\s+)([a-zA-Z_][a-zA-Z0-9_.]*)" }
      ]
    },
    "attributes": {
      "patterns": [
        {
          "name": "meta.annotation.ky",
          "begin": "#\\[",
          "end": "\\]",
          "patterns": [
            { "name": "entity.name.function.ky", "match": "\\b([a-z_][a-zA-Z0-9_]+)\\b" }
          ]
        }
      ]
    },
    "constructor_call": {
      "patterns": [
        {
          "match": "\\b([A-Z][a-zA-Z0-9_]*)\\s*\\{",
          "captures": {
            "1": { "name": "entity.name.type.ky" }
          }
        },
        {
          "match": "\\b([A-Z][a-zA-Z0-9_]*)\\s*\\(",
          "captures": {
            "1": { "name": "entity.name.type.ky" }
          }
        }
      ]
    },
    "property_access": {
      "name": "variable.other.property.ky",
      "match": "(?<=\\.)([a-zA-Z_][a-zA-Z0-9_]*)"
    },
    "variable_decl": {
      "patterns": [
        { "name": "variable.other.constant.ky", "match": "([A-Z_][A-Z0-9_]*)(?=\\s*:=)" },
        { "name": "variable.other.mutable.ky", "match": "([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*:\\s*&)" },
        { "name": "variable.other.ky", "match": "([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*=)" }
      ]
    },
    "mutable_var": {
      "name": "variable.other.mutable.ky",
      "match": "([a-z_][a-zA-Z0-9_]*)(?=\\s*:(\\s*[A-Za-z_][A-Za-z0-9_]*\\s*)?:=)"
    }
  }
}
